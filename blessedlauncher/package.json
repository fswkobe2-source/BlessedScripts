{
  "name": "blessed-launcher",
  "version": "1.0.1",
  "description": "Blessed Scripts Launcher with Jagex Account Integration",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:win-x64": "electron-builder --win --x64",
    "build:win-ia32": "electron-builder --win --ia32",
    "package:jpackage": "node scripts/build-jpackage.js"
  },
  "keywords": [
    "blessed-scripts",
    "osrs",
    "bot",
    "launcher"
  ],
  "author": "Blessed Scripts",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-log": "^5.0.0",
    "electron-updater": "^6.1.0",
    "patchright": "^1.58.2",
    "to-ico": "^1.1.5"
  },
  "build": {
    "appId": "com.blessedscripts.launcher",
    "productName": "Blessed Scripts Launcher",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "libs/**/*",
      "images/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../runelite-client/build/libs/BlessedScripts-2.1.25.jar",
        "to": "BlessedScripts-2.1.25.jar",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "BlessedScripts",
      "repo": "BlessedScripts"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/blessed-scripts.ico",
      "signAndEditExecutable": false,
      "signDlls": false,
      "publisherName": "Blessed Scripts",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "allowElevation": false,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Blessed Scripts",
      "deleteAppDataOnUninstall": true,
      "displayLanguageSelector": false,
      "installerHeaderIcon": "build/blessed-scripts.ico",
      "installerIcon": "build/blessed-scripts.ico",
      "uninstallerIcon": "build/blessed-scripts.ico",
      "installerSidebar": "images/installer_sidebar.bmp",
      "installerHeader": "images/installer_header.bmp",
      "license": "LICENSE.txt",
      "unicode": true,
      "guid": "com.blessedscripts.launcher",
      "runAfterFinish": true,
      "menuCategory": "Blessed Scripts",
      "artifactName": "${productName} Setup ${version}.${ext}"
    }
  }
}
